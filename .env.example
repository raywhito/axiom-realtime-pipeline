# Copy to .env (read by docker compose). Defaults are fine for a local demo.
PG_USER=axiom
PG_PASSWORD=axiom
PG_DB=axiom

TARGET_EPS=20          # telemetry events per second
INVALID_RATE=0.05      # share of intentionally malformed events (DLQ demo)

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
